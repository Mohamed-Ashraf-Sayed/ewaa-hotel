generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Hotel {
  id        Int      @id @default(autoincrement())
  name      String
  nameEn    String?
  location  String?  // optional — OTA ingest creates hotels with just name + IDs, location backfilled later
  city      String?
  country   String   @default("Saudi Arabia")
  stars     Int?
  type      String?
  group     String?  // muhaidib_serviced | awa_hotels | grand_plaza
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  // OTA matching keys — used by the OTA inbox poller to attach a parsed
  // reservation email to the right hotel record. Populated lazily on first
  // sighting of a hotel id from each platform.
  bookingComId String? @unique
  agodaId      String? @unique
  expediaId    String? @unique
  almosaferId  String? @unique
  aliases      String? // JSON array of alternate names seen in OTA emails

  // Bank account details — used in quote/offer "بيانات الدفع" section
  bankName        String?
  beneficiaryName String?
  nationalId      String?
  accountNumber   String?
  iban            String?

  clients    Client[]
  contracts  Contract[]
  bookings   Booking[]
  userHotels UserHotel[]
  quotes     Quote[]
  reservations    Reservation[]
  events          BookingEvent[]
}

model User {
  id             Int      @id @default(autoincrement())
  name           String
  email          String   @unique
  password       String
  role           String
  // Optional human-readable job title that overrides the role-based label
  // on the user's own screens (header / sidebar / PDF prepared-by). The
  // permissions vector still comes from `role`; this is display-only.
  title          String?
  managerId      Int?
  isActive       Boolean  @default(true)
  phone          String?
  commissionRate Float?   @default(0)
  smtpHost       String?
  smtpPort       Int?     @default(587)
  smtpEmail      String?
  smtpPassword   String?
  mustChangePassword Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  manager         User?   @relation("UserManager", fields: [managerId], references: [id])
  subordinates    User[]  @relation("UserManager")
  assignedClients Client[]
  contracts       Contract[]
  approvals       ContractApproval[]
  visits          Visit[]
  activities      Activity[]
  hotels          UserHotel[]
  pulseScores     DealPulseScore[]
  payments        Payment[]
  approvedPayments Payment[] @relation("PaymentApprover")
  targets         SalesTarget[]  @relation("TargetUser")
  setTargets      SalesTarget[]  @relation("TargetSetBy")
  notifications   Notification[]
  tasksAssigned   Task[]         @relation("TaskAssignee")
  tasksCreated    Task[]         @relation("TaskCreator")
  performanceScores PerformanceScore[] @relation("PerfUser")
  performanceRatings PerformanceScore[] @relation("PerfRatedBy")
  emailLogs       EmailLog[]
  reminders       Reminder[]
  uploadedAttachments ClientAttachment[]
  messagesSent    Message[]      @relation("MessagesSent")
  messagesReceived Message[]     @relation("MessagesReceived")
  localEvents     LocalEvent[]
  bookingsAssigned  Booking[]    @relation("BookingAssignedRep")
  bookingsBooked    Booking[]    @relation("BookingBookedBy")
  bookingsCancelled Booking[]    @relation("BookingCancelledBy")
  bookingChangesByMe BookingChangeLog[] @relation("BookingChangedBy")
  promotionsCreated Promotion[]  @relation("PromotionCreator")
  quotes            Quote[]
  quotesApproved    Quote[]      @relation("QuoteApprover")
}

model Message {
  id             Int      @id @default(autoincrement())
  fromUserId     Int
  toUserId       Int
  content        String
  attachmentUrl  String?
  attachmentName String?
  attachmentType String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  fromUser    User     @relation("MessagesSent", fields: [fromUserId], references: [id])
  toUser      User     @relation("MessagesReceived", fields: [toUserId], references: [id])

  @@index([fromUserId, toUserId])
  @@index([toUserId, isRead])
}

model UserHotel {
  userId  Int
  hotelId Int
  user    User  @relation(fields: [userId], references: [id])
  hotel   Hotel @relation(fields: [hotelId], references: [id])

  @@id([userId, hotelId])
}

model Client {
  id             Int      @id @default(autoincrement())
  companyName    String
  companyNameEn  String?
  contactPerson  String
  phone          String?
  email          String?
  address        String?
  industry       String?
  clientType     String   @default("lead")
  source         String?
  salesRepId     Int
  hotelId        Int?
  brands         String?  // comma-separated: muhaidib_serviced,awa_hotels,grand_plaza
  estimatedRooms Int?
  annualBudget   Float?
  creditLimit    Float?   // Maximum approved credit (City Ledger ceiling) for this corporate account
  website        String?
  commercialRegNo String?
  taxCardNo      String?
  latitude       Float?
  longitude      Float?
  notes          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  salesRep    User       @relation(fields: [salesRepId], references: [id])
  hotel       Hotel?     @relation(fields: [hotelId], references: [id])
  contracts   Contract[]
  visits      Visit[]
  activities  Activity[]
  pulseScore  DealPulseScore?
  payments    Payment[]
  tasks       Task[]
  emailLogs   EmailLog[]
  reminders   Reminder[]
  attachments ClientAttachment[]
  bookings    Booking[]
  inboxEmails InboxEmail[]
  quotes      Quote[]
}

model ClientAttachment {
  id           Int      @id @default(autoincrement())
  clientId     Int
  uploadedById Int
  type         String   // commercial_register | tax_card | id_copy | contract | other
  fileName     String
  fileUrl      String
  fileSize     Int?
  mimeType     String?
  notes        String?
  createdAt    DateTime @default(now())

  client     Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  uploadedBy User   @relation(fields: [uploadedById], references: [id])
}


model Contract {
  id             Int       @id @default(autoincrement())
  clientId       Int
  hotelId        Int
  salesRepId     Int
  fileUrl        String?
  fileName       String?
  roomsCount     Int?
  ratePerRoom    Float?
  startDate      DateTime?
  endDate        DateTime?
  totalValue     Float?
  collectedAmount Float?   @default(0)
  status         String    @default("pending")
  bookingConfirmed Boolean  @default(false)
  bookingConfirmedAt DateTime?
  bookingConfirmedBy Int?
  bookingNotes   String?
  confirmationLetterUrl String?
  confirmationLetterName String?
  notes          String?
  contractRef    String?
  paymentMethod  String?   // bank_transfer | cash | credit
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  client    Client             @relation(fields: [clientId], references: [id])
  hotel     Hotel              @relation(fields: [hotelId], references: [id])
  salesRep  User               @relation(fields: [salesRepId], references: [id])
  approvals ContractApproval[]
  payments  Payment[]
  tasks     Task[]
  bookings  Booking[]
}

model ContractApproval {
  id         Int      @id @default(autoincrement())
  contractId Int
  approvedBy Int
  status     String
  notes      String?
  createdAt  DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id])
  approver User     @relation(fields: [approvedBy], references: [id])
}

model Visit {
  id           Int       @id @default(autoincrement())
  clientId     Int
  salesRepId   Int
  visitDate    DateTime
  visitType    String?
  purpose      String?
  outcome      String?
  nextFollowUp DateTime?
  notes        String?
  createdAt    DateTime  @default(now())

  client   Client @relation(fields: [clientId], references: [id])
  salesRep User   @relation(fields: [salesRepId], references: [id])
}

model Activity {
  id          Int      @id @default(autoincrement())
  clientId    Int
  userId      Int
  type        String
  description String
  createdAt   DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])
  user   User   @relation(fields: [userId], references: [id])
}

// === PRICE QUOTES (saved per client so the rep can re-open / re-download) ===
model Quote {
  id           Int      @id @default(autoincrement())
  reference    String   @unique  // e.g. QT-12345678
  clientId     Int
  hotelId      Int?
  salesRepId   Int

  // The line items + computed totals are stored as JSON strings so the PDF
  // can be regenerated identically months later without depending on rates
  // or hotel data that may have changed since.
  items        String   // JSON array of {description,roomType,nights,rooms,rate,total}
  subtotal     Float
  munTaxRate   Float    @default(0)
  munTax       Float    @default(0)
  vat          Float
  grandTotal   Float

  validDays    Int      @default(30)
  validUntil   DateTime
  notes        String?
  lang         String   @default("ar")  // 'ar' | 'en'
  meals        String   @default("breakfast")  // none | breakfast | lunch | dinner | full_board
  preparedByTitle String?  // job title the rep typed for this quote (free-text, not derived from role)
  paymentTerms    String?  // free-text payment installments the rep typed per quote
  arrivalDate     DateTime?  // optional arrival date the rep entered for this quote

  // Approval workflow:
  // pending_manager_approval (default for new quotes the rep creates)
  //   → approved   (sales_director approved, visible to credit + reservations)
  //   → rejected   (sales_director rejected with reason)
  //   → closed     (a confirmed booking linked to this quote has finished —
  //                  the client needs a fresh quote to book again)
  status            String    @default("pending_manager_approval")
  approvalNote      String?   // approver's note on approval/rejection
  approvedById      Int?
  approvedAt        DateTime?
  closedAt          DateTime? // set when the linked booking's departure passes
  linkedBookingId   Int?      // the confirmed booking that consumed this quote

  approvedBy   User?    @relation("QuoteApprover", fields: [approvedById], references: [id])
  linkedBooking Booking? @relation("QuoteLinkedBooking", fields: [linkedBookingId], references: [id])

  createdAt    DateTime @default(now())

  client   Client @relation(fields: [clientId], references: [id])
  hotel    Hotel? @relation(fields: [hotelId], references: [id])
  salesRep User   @relation(fields: [salesRepId], references: [id])

  @@index([clientId])
  @@index([salesRepId])
}

// === PAYMENT / COLLECTION TRACKING ===
model Payment {
  id          Int      @id @default(autoincrement())
  contractId  Int
  clientId    Int
  amount      Float
  paymentDate DateTime
  paymentType String?  // cash | bank_transfer | check | online
  reference   String?
  notes       String?
  receiptUrl  String?  // uploaded receipt image/file filename
  collectedBy Int
  status         String   @default("pending") // pending | approved | rejected
  approvedById   Int?
  approvedAt     DateTime?
  approvalNotes  String?
  createdAt   DateTime @default(now())

  contract  Contract @relation(fields: [contractId], references: [id])
  client    Client   @relation(fields: [clientId], references: [id])
  collector User     @relation(fields: [collectedBy], references: [id])
  approver  User?    @relation("PaymentApprover", fields: [approvedById], references: [id])
}

// === IMAP ACCOUNTS — mailboxes the system polls for incoming emails ===
model ImapAccount {
  id              Int       @id @default(autoincrement())
  label           String    // friendly name, e.g. "Reservations"
  host            String
  port            Int       @default(993)
  secure          Boolean   @default(true)
  username        String    // login email
  password        String    // app password / mailbox password
  mailbox         String    @default("INBOX")
  isActive        Boolean   @default(true)
  captureAll      Boolean   @default(false) // false = only emails from registered clients; true = capture every email
  pollIntervalMs  Int       @default(180000)
  lastPolledAt    DateTime?
  lastError       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// === EMAIL INBOX (incoming emails from clients) ===
model InboxEmail {
  id            Int      @id @default(autoincrement())
  messageId     String   @unique // RFC822 Message-ID for dedup
  fromEmail     String
  fromName      String?
  toEmail       String?
  subject       String
  bodyText      String?  // plaintext body
  bodyHtml      String?  // HTML body if available
  receivedAt    DateTime
  category      String   @default("client") // client | reservations
  isRead        Boolean  @default(false)
  isReplied     Boolean  @default(false)
  hasAttachments Boolean @default(false)
  attachmentsJson String? // JSON array: [{filename, url, size}]
  clientId      Int?
  imapAccountId Int?     // which mailbox this came from
  createdAt     DateTime @default(now())

  client        Client?  @relation(fields: [clientId], references: [id])

  @@index([receivedAt])
  @@index([clientId])
  @@index([isRead])
}

// === SALES TARGETS ===
model SalesTarget {
  id              Int      @id @default(autoincrement())
  userId          Int
  setById         Int
  period          String   // monthly | quarterly
  month           Int?     // 1-12 for monthly
  quarter         Int?     // 1-4 for quarterly
  year            Int
  targetContracts Int?     @default(0)
  targetRevenue   Float?   @default(0)
  targetVisits    Int?     @default(0)
  targetClients   Int?     @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User @relation("TargetUser", fields: [userId], references: [id])
  setBy User @relation("TargetSetBy", fields: [setById], references: [id])

  @@unique([userId, period, year, month])
  @@unique([userId, period, year, quarter])
}

// === DEAL PULSE INTELLIGENCE ===
model DealPulseScore {
  id                 Int      @id @default(autoincrement())
  clientId           Int      @unique
  salesRepId         Int
  engagementScore    Int      @default(0)
  visitScore         Int      @default(0)
  contractScore      Int      @default(0)
  recencyScore       Int      @default(0)
  trend              String   @default("stable")
  riskLevel          String   @default("low")
  lastCalculated     DateTime @default(now())
  daysSinceLastVisit Int?
  suggestedAction    String?

  client   Client @relation(fields: [clientId], references: [id])
  salesRep User   @relation(fields: [salesRepId], references: [id])
}

// === CALENDAR REMINDERS ===
model Reminder {
  id          Int      @id @default(autoincrement())
  userId      Int
  clientId    Int?
  title       String
  description String?
  reminderDate DateTime
  reminderTime String?  // HH:mm
  type        String   @default("general") // call | visit | meeting | follow_up | general
  isCompleted Boolean  @default(false)
  notified    Boolean  @default(false)
  createdAt   DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
}

// === EMAIL LOG ===
model EmailLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  clientId  Int?
  to        String
  subject   String
  body      String
  status    String   @default("sent") // sent | failed
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id])
  client Client? @relation(fields: [clientId], references: [id])
}

// === NOTIFICATIONS ===
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // contract_expiring | target_missed | pending_approval | client_inactive | task_assigned | general
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// === TASK MANAGEMENT ===
model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  taskType    String    @default("general") // visit | call | meeting | follow_up | general
  assigneeId  Int
  createdById Int
  clientId    Int?
  contractId  Int?
  priority    String    @default("normal") // urgent | normal
  status      String    @default("new")    // new | in_progress | completed
  dueDate     DateTime?
  completedAt DateTime?
  completionNotes String?
  generatedVisitId Int?
  overdueNotified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assignee  User      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  createdBy User      @relation("TaskCreator", fields: [createdById], references: [id])
  client    Client?   @relation(fields: [clientId], references: [id])
  contract  Contract? @relation(fields: [contractId], references: [id])
}

model PasswordResetCode {
  id         Int      @id @default(autoincrement())
  email      String
  codeHash   String
  expiresAt  DateTime
  used       Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([email, used])
  @@index([expiresAt])
}

// === CLIENT PORTAL OTP (login codes for client self-service portal) ===
model ClientOtpCode {
  id         Int      @id @default(autoincrement())
  email      String
  codeHash   String
  expiresAt  DateTime
  used       Boolean  @default(false)
  attempts   Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([email, used])
  @@index([expiresAt])
}

// === LOCAL EVENTS / HOLIDAYS ===
model LocalEvent {
  id          Int       @id @default(autoincrement())
  title       String
  titleEn     String?
  description String?
  eventDate   DateTime
  endDate     DateTime?
  type        String    @default("occasion") // official_holiday | religious | school | season | occasion
  color       String?
  isRecurring Boolean   @default(false)
  source      String    @default("manual")  // manual | nager
  externalId  String?
  createdById Int?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  createdBy User? @relation(fields: [createdById], references: [id])

  @@unique([source, externalId])
  @@index([eventDate])
}

// === BOOKINGS (per-stay reservations from Opera) ===
model Booking {
  id                    Int       @id @default(autoincrement())
  clientId              Int
  hotelId               Int
  contractId            Int?
  assignedRepId         Int
  bookedById            Int?      // null when submitted via client self-service portal
  submittedByClient     Boolean   @default(false)

  operaConfirmationNo   String?   // null until reservations team confirms in Opera (for portal-submitted bookings)
  guestName             String
  reservationMadeBy     String?

  arrivalDate           DateTime
  departureDate         DateTime
  nights                Int

  roomsCount            Int       @default(1)
  adultsCount           Int       @default(1)
  childrenCount         Int       @default(0)
  roomType              String?

  ratePerNight          Float?
  ratePackage           String?
  totalAmount           Float?
  currency              String    @default("SAR")
  vatPercent            Float     @default(15)
  municipalityFeePercent Float    @default(2.5)

  paymentMethod         String?
  source                String    @default("outlook")

  status                String    @default("confirmed")  // pending_reservations | confirmed | checked_in | checked_out | cancelled | no_show
  cancelledAt           DateTime?
  cancelledById         Int?
  cancellationReason    String?

  confirmationLetterUrl  String?
  confirmationLetterName String?

  notes                 String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  client       Client    @relation(fields: [clientId], references: [id])
  hotel        Hotel     @relation(fields: [hotelId], references: [id])
  contract     Contract? @relation(fields: [contractId], references: [id])
  assignedRep  User      @relation("BookingAssignedRep", fields: [assignedRepId], references: [id])
  bookedBy     User?     @relation("BookingBookedBy", fields: [bookedById], references: [id])
  cancelledBy  User?     @relation("BookingCancelledBy", fields: [cancelledById], references: [id])
  changeLogs   BookingChangeLog[]
  guests       BookingGuest[]
  fundingQuotes Quote[]  @relation("QuoteLinkedBooking")

  @@index([clientId])
  @@index([hotelId])
  @@index([assignedRepId])
  @@index([status])
  @@index([arrivalDate])
  @@index([operaConfirmationNo])
}

// === MARKETING PROMOTIONS (banner ads on dashboard) ===
// A campaign auto-shows on the user's home dashboard between startsAt and
// endsAt. hotelIds / brands are optional CSV filters; both null means show
// to everyone.
model Promotion {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  imageUrl     String?
  ctaLabel     String?
  ctaUrl       String?
  startsAt     DateTime
  endsAt       DateTime
  hotelIds     String?  // comma-separated; null = all hotels
  brands       String?  // comma-separated brand groups; null = all brands
  isActive     Boolean  @default(true)
  createdById  Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdBy    User     @relation("PromotionCreator", fields: [createdById], references: [id])

  @@index([startsAt, endsAt])
  @@index([isActive])
}

// === BOOKING GUESTS (multi-guest support) ===
// One row per guest on a booking. The first/primary guest's name is also
// mirrored to Booking.guestName for backward compatibility with code that
// shows a single guest name.
model BookingGuest {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  name        String
  nationality String?
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())

  booking     Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
}

// === BOOKING CHANGE LOG (audit trail for edits/cancellations) ===
model BookingChangeLog {
  id          Int      @id @default(autoincrement())
  bookingId   Int
  changedById Int
  action      String   // edit | cancel | status_change | reactivate
  reason      String   // mandatory — sبب التعديل/الإلغاء
  changesJson String?  // JSON: { fieldName: { from, to } }
  fieldsList  String?  // comma-separated changed field names for quick display
  createdAt   DateTime @default(now())

  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  changedBy User    @relation("BookingChangedBy", fields: [changedById], references: [id])

  @@index([bookingId])
  @@index([createdAt])
}

// === PERFORMANCE & GAMIFICATION ===
model PerformanceScore {
  id          Int      @id @default(autoincrement())
  userId      Int
  ratedById   Int
  month       Int
  year        Int
  points      Int      @default(0)
  rating      Int?     // 1-5
  notes       String?
  createdAt   DateTime @default(now())

  user    User @relation("PerfUser", fields: [userId], references: [id])
  ratedBy User @relation("PerfRatedBy", fields: [ratedById], references: [id])

  @@unique([userId, month, year])
}

// === OTA BOOKINGS (ported from ewaa-bookings) ===
// Reservations + events parsed from OTA emails (Booking.com / Expedia /
// Agoda / Almosafer / channel managers). Separate from the existing
// `Booking` model which represents B2B corporate stays managed via Opera.
// Source-of-truth is the email — every event is keyed back to the
// BookingEmail row that produced it for audit.
model Reservation {
  id              Int       @id @default(autoincrement())
  externalId      String
  source          String    // Booking.com | Expedia | Agoda | Almosafer | Trip.com | channel_manager | Other
  hotelId         Int?
  guestName       String?
  checkIn         DateTime?
  checkOut        DateTime?
  nights          Int?
  rooms           Int?
  roomType        String?
  totalPrice      Float?
  currency        String?
  currentStatus   String    @default("confirmed") // confirmed | cancelled | modified
  firstSeenAt     DateTime  @default(now())
  lastUpdatedAt   DateTime  @updatedAt

  hotel           Hotel?    @relation(fields: [hotelId], references: [id])
  events          BookingEvent[]

  @@unique([source, externalId])
  @@index([hotelId])
  @@index([currentStatus])
}

model BookingEmail {
  id            Int       @id @default(autoincrement())
  messageId     String    @unique
  uid           Int?
  mailbox       String?
  fromAddr      String
  toAddr        String?
  subject       String
  receivedAt    DateTime
  rawText       String
  rawHtml       String?
  parseStatus   String    @default("pending") // pending | parsed | manual_review | skipped | failed
  parseError    String?
  parseMethod   String?   // regex:booking.com | ai:expedia | etc.
  parsedAt      DateTime?
  createdAt     DateTime  @default(now())

  events        BookingEvent[]

  @@index([receivedAt])
  @@index([parseStatus])
}

model BookingEvent {
  id              Int       @id @default(autoincrement())
  reservationId   Int
  emailId         Int
  hotelId         Int?
  eventType       String    // new | cancellation | modification
  snapshot        String    // JSON snapshot of the parsed payload at this event
  occurredAt      DateTime
  createdAt       DateTime  @default(now())

  reservation     Reservation  @relation(fields: [reservationId], references: [id])
  email           BookingEmail @relation(fields: [emailId], references: [id])
  hotel           Hotel?       @relation(fields: [hotelId], references: [id])

  @@index([hotelId, occurredAt])
  @@index([eventType, occurredAt])
  @@index([occurredAt])
}

// OTA inbox config — separate from the existing ImapAccount which is used
// to poll incoming client emails. Multiple accounts not needed yet but
// the schema mirrors the source app's so we can sync any updates back.
model OtaImapAccount {
  id              Int       @id @default(autoincrement())
  name            String    @default("Default")
  host            String
  port            Int       @default(993)
  secure          Boolean   @default(true)
  user            String
  password        String
  mailbox         String    @default("INBOX")
  pollIntervalSec Int       @default(120)
  enabled         Boolean   @default(true)
  lastPollAt      DateTime?
  lastError       String?
  lastTestedAt    DateTime?
  lastTestOk      Boolean?
  lastSeenUid     Int?
  oldestSeenUid   Int?
  serverMessageCount Int?
  totalFetched    Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

// === OTA branch inventory ===
// Independent table for the bookings analytics — lists every Ewaa/Muhaidib/
// Grand Plaza branch and how many rooms it has. Stored separately from the
// main Hotel model so the legacy CRM Hotel rows (used by Bookings, Contracts,
// Quotes, etc.) stay untouched. Used to compute "OTA bookings share of
// capacity" per branch.
model OtaBranchInventory {
  id        Int      @id @default(autoincrement())
  brand     String   // muhaidib_serviced | awa_hotels | grand_plaza
  name      String
  nameAlt   String?  // alternate name if email/UI uses a different spelling
  rooms     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([brand])
}
